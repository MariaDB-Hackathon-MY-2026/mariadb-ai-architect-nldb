# MariaDB — same values you use in Beekeeper / DBeaver
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_DATABASE=mariadb_ai_architect

# LLM (optional) — ollama | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

OPENAI_API_KEY=

# App secret (used to encrypt stored connector passwords)
# Change this before deploying.
APP_SECRET_KEY=dev-secret-change-me
